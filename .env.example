# Copie para .env e preencha com valores reais.
# .env NUNCA deve ser commitado (ver .gitignore) — docs/specs/fase5-seguranca.md seção 9.

# --- Postgres ---
POSTGRES_USER=fireaudit
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fireaudit
DATABASE_URL=postgresql+asyncpg://fireaudit:changeme@postgres:5432/fireaudit

# --- Autenticação (fase5-seguranca.md secao 2) ---
JWT_SECRET=changeme-generate-a-long-random-value
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Stripe (billing, fase8-design-api.md secao 3) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_INDIVIDUAL_PRO=
STRIPE_PRICE_ID_INDIVIDUAL_PREMIUM=
STRIPE_PRICE_ID_MULTIEMPRESA_BASE=

# --- KMS / segredos de webhook (fase5-seguranca.md secao 3) ---
# Usado para criptografia reversível de alert_channels.config. No MVP em OCI, isso é o OCI Vault.
KMS_PROVIDER=oci_vault
KMS_KEY_OCID=

# --- CORS (fase5-seguranca.md secao 6) ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Agente / ingestão ---
AGENT_DISTRIBUTION_URL=https://cdn.fireaudit.io/agent/latest.sh

# --- Observabilidade (fase9-10-performance-infra.md secao 2.3) ---
SENTRY_DSN=
